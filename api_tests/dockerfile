# api_tests/Dockerfile
FROM python:3.10-slim

WORKDIR /app

# Устанавливаем системные зависимости (если нужны, например postgresql-client для wait)
RUN apt-get update && apt-get install -y \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Копируем requirements из api (или создай отдельный requirements-test.txt)
COPY api/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Копируем весь код проекта (тесты + api)
COPY . .

# Если есть wait-for-postgres.sh в api/ — копируем его
COPY api/wait-for-postgres.sh /usr/local/bin/wait-for-postgres.sh
RUN chmod +x /usr/local/bin/wait-for-postgres.sh

# Устанавливаем рабочую директорию и PYTHONPATH
ENV PYTHONPATH=/app